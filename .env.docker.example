# Docker environment template — copy to .env.docker and fill in your values
# This file is loaded automatically by docker compose

# PostgreSQL
DB_HOST=postgres
PORT_POSTGRES=5432
DB_NAME=hacksmc
DB_USER=hacksmc
DB_PASSWORD=changeme

# JWT
JWT_SECRET=change-me-to-a-random-48-char-string-minimum!!
JWT_EXPIRATION_MS=3600000

# pfSense
PFSENSE_BASE_URL=https://pfsense.local
PFSENSE_API_KEY=your-pfsense-api-key-here
PFSENSE_TRUST_ALL_CERTS=false

# Admin-Passwort (wird beim Start gesetzt/aktualisiert)
ADMIN_PASSWORD=admin

# Ports
PORT_BACKEND=3000
NGINX_PORT=80
